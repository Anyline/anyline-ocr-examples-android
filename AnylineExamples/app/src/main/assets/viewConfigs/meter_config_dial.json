{
    "scanViewConfigDescription": "Optimized for dial meters.",
    "cameraConfig": {
        "captureResolution": "1080p",
        "pictureResolution": "1080p"
    },
    "flashConfig": {
        "mode": "manual",
        "alignment": "bottom_right"
    },
    "viewPluginConfig": {
        "pluginConfig": {
            "id": "Meter|Dial",
            "meterConfig": {
                "scanMode": "dial_meter"
            },
            "cancelOnResult": true
        },
        "cutoutConfig": {
            "maxWidthPercent": "85%",
            "alignment": "top",
